# Copy to app/.env for local development. Dev-only — never used in production
# builds (the app is served same-origin behind the engine's Apache).
ENGINE_URL=https://engine.lab.local/ovirt-engine

# Mock scale (npm run dev:mock only): when > 0 the mock appends that many
# generated VMs (vm-scale-1..N, deterministic statuses cycling by index) to
# the handcrafted fixtures — enough rows to exercise the VMs table's
# virtualized windowing. Unset/0/junk = fixtures only.
VITE_MOCK_SCALE=0
