{
  "name": "ovirt-web-ui-ng",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_MOCK=1 vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint && prettier --check src",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "format": "prettier --write src",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "verify:engine": "node ../scripts/verify-live-engine.mjs",
    "deploy:engine": "bash ../scripts/deploy-engine.sh"
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "@patternfly/react-charts": "^8.6.0",
