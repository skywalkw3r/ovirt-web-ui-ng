    "@patternfly/react-table": "^6.6.0",
    "@patternfly/react-tokens": "^6.6.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-virtual": "^3.14.5",
    "cmdk": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-intl": "^10.1.14",
    "victory-area": "^37.3.6",
    "victory-axis": "^37.3.6",
    "victory-bar": "^37.3.6",
    "victory-box-plot": "^37.3.6",
    "victory-chart": "^37.3.6",
    "victory-core": "^37.3.6",
    "victory-create-container": "^37.3.6",
